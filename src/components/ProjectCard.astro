---
import fs from 'node:fs';
import path from 'node:path';
import type { CollectionEntry } from 'astro:content';
import Placeholder from './Placeholder.astro';

interface Props {
  project: CollectionEntry<'projects'>;
}
const { project } = Astro.props;
const { title, summary, telemetry, tags, cover } = project.data;
const coverExists =
  cover && fs.existsSync(path.join(process.cwd(), 'public', 'images', cover));
---
<a class="card" href={`/projects/${project.id}/`}>
  {
    coverExists ? (
      <img class="cover" src={`/images/${cover}`} alt={title} loading="lazy" />
    ) : (
      <Placeholder label={`PHOTO — ${title.toUpperCase()}`} />
    )
  }
  <span class="tele mono-label">{telemetry}</span>
  <h3>{title}</h3>
  <p>{summary}</p>
  <span class="tags mono-label">{tags.join(' · ')}</span>
</a>

<style>
  .card {
    display: flex;
    flex-direction: column;
    gap: 0.65rem;
    background: var(--panel);
    border: 1px solid var(--line);
    padding: 0.9rem;
    text-decoration: none;
    transition: border-color 0.15s, transform 0.15s;
  }
  .card:hover { border-color: var(--accent); }
  @media (prefers-reduced-motion: no-preference) {
    .card:hover { transform: translateY(-2px); }
  }
  .cover { aspect-ratio: 16/10; object-fit: cover; border: 1px solid var(--line); width: 100%; }
  .tele { color: var(--accent); }
  h3 { font-size: 1.12rem; font-weight: 700; letter-spacing: -0.005em; }
  p { font-size: 0.86rem; line-height: 1.55; color: var(--muted); margin: 0; flex: 1; }
  .tags { color: var(--muted); font-size: 0.58rem; }
</style>
