---
/**
 * Live double-pendulum simulation (RK4) drawn on a canvas —
 * the trace of the second bob, glowing amber. It's Benjamin's own
 * double-pendulum project doubling as the site's hero graphic.
 */
interface Props {
  caption?: string;
}
const { caption = 'LIVE SIM — DOUBLE PENDULUM · RK4 · θ₀ = 120°' } = Astro.props;
---
<figure class="pendulum">
  <canvas data-pendulum aria-label="Live double pendulum simulation tracing a chaotic path"></canvas>
  <figcaption class="mono-label">{caption}</figcaption>
</figure>

<style>
  .pendulum { margin: 0; position: relative; }
  canvas { display: block; width: 100%; aspect-ratio: 1 / 1; }
  figcaption { position: absolute; left: 0; bottom: 0; color: var(--muted); font-size: 0.6rem; }
</style>

<script>
  function simulate(steps: number, dt: number) {
    // two unit masses on unit rods, released at 120 degrees
    let s = [2.0944, 2.0944, 0, 0];
    const g = 9.81;
    function deriv(st: number[]) {
      const [a, b, da, db] = st;
      const d = a - b;
      const den = 3 - Math.cos(2 * d);
      const dda =
        (-3 * g * Math.sin(a) - g * Math.sin(a - 2 * b) - 2 * Math.sin(d) * (db * db + da * da * Math.cos(d))) / den;
      const ddb = (2 * Math.sin(d) * (2 * da * da + 2 * g * Math.cos(a) + db * db * Math.cos(d))) / den;
      return [da, db, dda, ddb];
    }
    const pts: number[][] = [];
    for (let i = 0; i < steps; i++) {
      const k1 = deriv(s);
      const s2 = s.map((v, j) => v + (dt / 2) * k1[j]);
      const k2 = deriv(s2);
      const s3 = s.map((v, j) => v + (dt / 2) * k2[j]);
      const k3 = deriv(s3);
      const s4 = s.map((v, j) => v + dt * k3[j]);
      const k4 = deriv(s4);
      s = s.map((v, j) => v + (dt / 6) * (k1[j] + 2 * k2[j] + 2 * k3[j] + k4[j]));
      pts.push([Math.sin(s[0]) + Math.sin(s[1]), Math.cos(s[0]) + Math.cos(s[1]), s[0], s[1]]);
    }
    return pts;
  }

  function setup(canvas: HTMLCanvasElement) {
    const ctx = canvas.getContext('2d');
    if (!ctx) return;
    const css = getComputedStyle(document.documentElement);
    const accent = css.getPropertyValue('--accent').trim() || '#f2a33c';
    const ink = css.getPropertyValue('--ink').trim() || '#e9e8e3';

    const PTS = simulate(6000, 0.005);
    const reduced = window.matchMedia('(prefers-reduced-motion: reduce)').matches;
    const dpr = window.devicePixelRatio || 1;
    const W = (canvas.width = Math.max(1, canvas.offsetWidth * dpr));
    const H = (canvas.height = Math.max(1, canvas.offsetHeight * dpr));
    const cx = W / 2, cy = H / 2, sc = Math.min(W, H) / 4.7;
    const px = (p: number[]) => [cx + p[0] * sc, cy + p[1] * sc];

    function strokePath(n: number, width: number, alpha: number) {
      ctx!.beginPath();
      const p0 = px(PTS[0]);
      ctx!.moveTo(p0[0], p0[1]);
      for (let i = 1; i < n; i++) {
        const p = px(PTS[i]);
        ctx!.lineTo(p[0], p[1]);
      }
      ctx!.strokeStyle = accent;
      ctx!.globalAlpha = alpha;
      ctx!.lineWidth = width;
      ctx!.lineJoin = 'round';
      ctx!.stroke();
      ctx!.globalAlpha = 1;
    }

    function drawArms(n: number) {
      const st = PTS[Math.max(0, n - 1)];
      const j1 = px([Math.sin(st[2]), Math.cos(st[2])]);
      const j2 = px([st[0], st[1]]);
      const o = px([0, 0]);
      ctx!.strokeStyle = ink;
      ctx!.lineWidth = 1.4 * dpr;
      ctx!.beginPath();
      ctx!.moveTo(o[0], o[1]);
      ctx!.lineTo(j1[0], j1[1]);
      ctx!.lineTo(j2[0], j2[1]);
      ctx!.stroke();
      ctx!.fillStyle = ink;
      for (const pt of [o, j1, j2]) {
        ctx!.beginPath();
        ctx!.arc(pt[0], pt[1], 2.4 * dpr, 0, 6.2832);
        ctx!.fill();
      }
    }

    function render(n: number) {
      ctx!.clearRect(0, 0, W, H);
      strokePath(n, 6 * dpr, 0.1);
      strokePath(n, 2.6 * dpr, 0.2);
      strokePath(n, 1.15 * dpr, 0.92);
      drawArms(n);
    }

    if (reduced) {
      render(PTS.length);
      return;
    }
    let i = 2;
    function frame() {
      i = Math.min(PTS.length, i + 34);
      render(i);
      if (i < PTS.length) requestAnimationFrame(frame);
    }
    requestAnimationFrame(frame);
  }

  document.querySelectorAll<HTMLCanvasElement>('[data-pendulum]').forEach(setup);
</script>
