<footer id="contact" class="site-foot">
  <div class="wrap inner">
    <div class="left">
      <p class="head mono-label">CONTACT</p>
      <a class="mail" href="mailto:benjamintranpugh@gmail.com">benjamintranpugh@gmail.com</a>
      <p class="alt mono-label">BTRANPUG@UWATERLOO.CA · +1 (647) 768-1669</p>
    </div>
    <div class="right">
      <a class="btn" href="https://github.com/BenjaminTP">GITHUB ↗</a>
      <a class="btn" href="https://linkedin.com/in/benjamin-tran-pugh">LINKEDIN ↗</a>
    </div>
  </div>
  <div class="wrap base">
    <span class="mono-label">© 2026 BENJAMIN TRAN-PUGH</span>
    <span class="mono-label">WATERLOO, ON — BENJAMINTRANPUGH.COM</span>
  </div>
</footer>

<style>
  .site-foot { border-top: 1px solid var(--line); margin-top: var(--space); background: var(--panel-2); }
  .inner {
    display: flex;
    justify-content: space-between;
    align-items: flex-end;
    gap: 1.5rem;
    flex-wrap: wrap;
    padding-top: 2.2rem;
    padding-bottom: 2.2rem;
  }
  .head { color: var(--accent); margin: 0 0 0.6rem; }
  .mail {
    font-size: clamp(1.15rem, 2.6vw, 1.7rem);
    font-weight: 700;
    letter-spacing: -0.01em;
    color: var(--ink);
    text-decoration: none;
    border-bottom: 2px solid var(--accent);
  }
  .mail:hover { color: var(--accent); }
  .alt { color: var(--muted); margin: 0.8rem 0 0; }
  .right { display: flex; gap: 0.7rem; }
  .base {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    flex-wrap: wrap;
    border-top: 1px solid var(--line);
    padding-top: 0.9rem;
    padding-bottom: 1.1rem;
  }
  .base .mono-label { color: var(--muted); font-size: 0.6rem; }
</style>
