---
/**
 * Privacy-friendly YouTube embed for project pages.
 * Usage in .mdx: <YouTube id="uuaAOCRsIaw" caption="FULL DEMO" />
 */
interface Props {
  id: string;
  title?: string;
  caption?: string;
}
const { id, title = 'YouTube video', caption } = Astro.props;
---
<figure class="yt">
  <div class="frame">
    <iframe
      src={`https://www.youtube-nocookie.com/embed/${id}`}
      title={title}
      loading="lazy"
      allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
      allowfullscreen
    ></iframe>
  </div>
  {caption && <figcaption class="mono-label">{caption}</figcaption>}
</figure>

<style>
  .yt { margin: 1.6rem 0; }
  .frame { aspect-ratio: 16 / 9; border: 1px solid var(--line); background: #000; }
  iframe { width: 100%; height: 100%; display: block; border: 0; }
  figcaption { color: var(--muted); font-size: 0.62rem; padding-top: 0.55rem; }
</style>
