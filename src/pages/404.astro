---
import Base from '../layouts/Base.astro';
---
<Base title="404 — Benjamin Tran-Pugh">
  <main class="wrap nf">
    <p class="code display">404</p>
    <p class="msg mono-label">PAGE NOT FOUND — SIGNAL LOST</p>
    <a class="btn" href="/">← BACK TO HOME</a>
  </main>
</Base>

<style>
  .nf { text-align: center; padding-top: 14vh; padding-bottom: 14vh; }
  .code { font-size: clamp(5rem, 18vw, 12rem); color: var(--accent); }
  .msg { color: var(--muted); margin: 1rem 0 2rem; }
</style>
