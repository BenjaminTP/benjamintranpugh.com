---
import { getCollection, render } from 'astro:content';
import Base from '../../layouts/Base.astro';
import Figure from '../../components/Figure.astro';
import Compare from '../../components/Compare.astro';
import Gallery from '../../components/Gallery.astro';
import Sim from '../../components/Sim.astro';
import Stats from '../../components/Stats.astro';
import YouTube from '../../components/YouTube.astro';

export async function getStaticPaths() {
  const projects = await getCollection('projects');
  return projects.map((p) => ({ params: { slug: p.id }, props: { project: p } }));
}

const { project } = Astro.props;
const { Content } = await render(project);
const { title, telemetry, tags, github, writeup, summary } = project.data;

// files already placed inline via <Figure>, plus the cover (already on the
// card), so the gallery skips them and nothing appears on the page twice
const inlineMedia = [
  ...[...(project.body ?? '').matchAll(/src="([^"]+)"/g)].map((m) => m[1]),
  project.data.cover ?? '',
];

const all = (await getCollection('projects')).sort((a, b) => a.data.order - b.data.order);
const i = all.findIndex((p) => p.id === project.id);
const prev = all[i - 1];
const next = all[i + 1];
---
<Base title={`${title} | Benjamin Tran-Pugh`} description={summary}>
  <main class="wrap">
    <header class="head">
      <a class="back mono-label" href="/#work">← ALL PROJECTS</a>
      <h1 class="display">{title}</h1>
      <p class="tele mono-label">{telemetry}</p>
      <p class="meta mono-label">{tags.join(' / ')}</p>
      {
        (writeup || github) && (
          <div class="links">
            {writeup && (
              <a class="btn solid" href={writeup}>
                READ MY FULL WRITEUP ↗
              </a>
            )}
            {github && (
              <a class="btn" href={github}>
                SOURCE ON GITHUB ↗
              </a>
            )}
          </div>
        )
      }
      {
        writeup && (
          <p class="linknote mono-label">
            I WROTE IT MYSELF: EVERY DERIVATION, PARAMETER CHOICE, AND TEST CASE AT FULL
            LENGTH. THE REPO IS THE CODE BEHIND IT.
          </p>
        )
      }
    </header>

    <article class="prose">
      <Content components={{ Figure, Compare, Sim, Stats, YouTube }} />
    </article>

    <Gallery slug={project.id} exclude={inlineMedia} />

    <nav class="pn" aria-label="Project navigation">
      {prev ? <a class="btn" href={`/projects/${prev.id}/`}>← {prev.data.title.toUpperCase()}</a> : <span></span>}
      {next ? <a class="btn" href={`/projects/${next.id}/`}>{next.data.title.toUpperCase()} →</a> : <span></span>}
    </nav>
  </main>
</Base>

<style>
  /* narrower, centered reading column (overrides .wrap's site-wide width) */
  main { max-width: 48rem; }
  article.prose { max-width: none; }
  .head { padding-top: 1.8rem; border-bottom: 1px solid var(--line); padding-bottom: 1.4rem; }
  .back { color: var(--muted); text-decoration: none; }
  .back:hover { color: var(--accent); }
  h1 { font-size: clamp(2.4rem, 7vw, 4.8rem); margin: 0.8rem 0 0.9rem; }
  .tele { color: var(--accent); margin: 0 0 0.5rem; }
  .meta { color: var(--muted); margin: 0; }
  .links { display: flex; gap: 0.7rem; flex-wrap: wrap; margin-top: 1.1rem; }
  .linknote { color: var(--muted); margin: 0.7rem 0 0; max-width: 34rem; line-height: 1.7; }
  .prose { padding-top: 0.6rem; }
  .pn {
    display: flex;
    justify-content: space-between;
    gap: 1rem;
    border-top: 1px solid var(--line);
    margin-top: 2.5rem;
    padding-top: 1.2rem;
  }
</style>
