---
import { getCollection } from 'astro:content';
import Base from '../layouts/Base.astro';
import ProjectCard from '../components/ProjectCard.astro';

const projects = (await getCollection('projects')).sort(
  (a, b) => a.data.order - b.data.order
);

// structured data so search engines connect the site to Benjamin by name
const personSchema = {
  '@context': 'https://schema.org',
  '@type': 'Person',
  name: 'Benjamin Tran-Pugh',
  url: 'https://benjamintranpugh.com',
  jobTitle: 'Mechanical Engineering Student',
  affiliation: { '@type': 'CollegeOrUniversity', name: 'University of Waterloo' },
  email: 'mailto:benjamintranpugh@gmail.com',
  sameAs: [
    'https://github.com/BenjaminTP',
    'https://linkedin.com/in/benjamin-tran-pugh',
  ],
};
---
<Base title="Benjamin Tran-Pugh — Mechanical Engineering, University of Waterloo">
  <script type="application/ld+json" set:html={JSON.stringify(personSchema)} />
  <main>
    <section class="hero wrap">
      <div class="intro">
        <p class="kicker mono-label">MECHANICAL ENGINEERING — UNIVERSITY OF WATERLOO</p>
        <h1 class="display name">Benjamin<br />Tran&#8209;Pugh</h1>
        <p class="readout mono-label">
          FOCUS&nbsp;&nbsp;: ROBOTICS / AEROSPACE / AUTOMOTIVE<br />
          CAD&nbsp;&nbsp;&nbsp;&nbsp;: SOLIDWORKS · ONSHAPE · INVENTOR · FUSION 360 · AUTOCAD<br />
          SIM&nbsp;&nbsp;&nbsp;&nbsp;: FEA (SOLIDWORKS, ANSYS) · CAE · PYTHON / MATLAB MODELS<br />
          CODE&nbsp;&nbsp;&nbsp;: PYTHON · C/C++ · MATLAB · ESP32 / ARDUINO<br />
          STATUS : MECHANICAL ENGINEERING INTERN AT HUMAN COMPUTER LAB
        </p>
        <div class="cta">
          <a class="btn solid" href="/resume/">RESUME</a>
          <a class="btn" href="https://github.com/BenjaminTP">GITHUB ↗</a>
          <a class="btn" href="https://linkedin.com/in/benjamin-tran-pugh">LINKEDIN ↗</a>
        </div>
      </div>
      <a class="feature" href="/projects/robot-arm-2/">
        <video src="/images/robot-arm-2/orbit.mp4" autoplay loop muted playsinline aria-label="Robot Arm 2.0 — CAD orbit animation in SolidWorks"></video>
        <span class="mono-label">ROBOT ARM 2.0 — CAD ORBIT · SOLIDWORKS</span>
      </a>
    </section>

    <section id="work" class="wrap">
      <div class="workhead">
        <h2 class="mono-label">SELECTED WORK</h2>
        <span class="mono-label count">{String(projects.length).padStart(2, '0')} PROJECTS</span>
      </div>
      <div class="grid">
        {projects.map((p) => <ProjectCard project={p} />)}
      </div>
    </section>
  </main>
</Base>

<style>
  .hero {
    display: grid;
    grid-template-columns: minmax(0, 7fr) minmax(0, 5fr);
    gap: clamp(1.5rem, 4vw, 3.5rem);
    align-items: center;
    padding-top: clamp(1.6rem, 4vw, 3.2rem);
    padding-bottom: clamp(1.6rem, 4vw, 3.2rem);
  }
  .kicker { color: var(--accent); margin: 0 0 1rem; }
  .name { font-size: clamp(3.2rem, 9.5vw, 7.5rem); }
  .readout { color: var(--muted); line-height: 2; margin: 1.3rem 0 1.5rem; }
  .cta { display: flex; gap: 0.7rem; flex-wrap: wrap; }

  .workhead {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    border-top: 1px solid var(--line);
    padding-top: 0.8rem;
    margin-bottom: 1.2rem;
  }
  .count { color: var(--muted); }
  .feature {
    display: block;
    background: var(--panel);
    border: 1px solid var(--line);
    padding: 0.7rem;
    text-decoration: none;
    transition: border-color 0.15s;
  }
  .feature:hover { border-color: var(--accent); }
  .feature img, .feature video { width: 100%; aspect-ratio: 16 / 11; object-fit: cover; border: 1px solid var(--line); display: block; }
  .feature .mono-label { display: block; color: var(--muted); font-size: 0.6rem; padding-top: 0.6rem; }
  .grid {
    display: grid;
    grid-template-columns: repeat(3, minmax(0, 1fr));
    gap: 1rem;
  }
  @media (max-width: 900px) {
    .grid { grid-template-columns: repeat(2, minmax(0, 1fr)); }
  }
  @media (max-width: 640px) {
    .hero { grid-template-columns: 1fr; }
    .grid { grid-template-columns: 1fr; }
  }
</style>
