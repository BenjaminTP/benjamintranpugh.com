---
import fs from 'node:fs';
import path from 'node:path';
import Base from '../layouts/Base.astro';

// The resume shows a live preview of public/resume.pdf. The page images are
// rendered from the PDF automatically at build time (see astro.config.mjs +
// scripts/render-resume.mjs). To update: replace public/resume.pdf and push.
const pub = path.join(process.cwd(), 'public');
const pdfExists = fs.existsSync(path.join(pub, 'resume.pdf'));
const pages = fs.existsSync(pub)
  ? fs
      .readdirSync(pub)
      .filter((f) => /^resume-page-\d+\.png$/.test(f))
      .sort((a, b) => a.localeCompare(b, undefined, { numeric: true }))
  : [];
---
<Base title="Resume — Benjamin Tran-Pugh">
  <main class="wrap">
    <header class="head">
      <h1 class="display">Resume</h1>
      {
        pdfExists && (
          <a class="btn solid" href="/resume.pdf" download>DOWNLOAD PDF ↓</a>
        )
      }
    </header>

    {
      pages.length > 0 ? (
        <div class="preview">
          {pages.map((p, i) => (
            <img
              src={`/${p}`}
              alt={`Benjamin Tran-Pugh resume, page ${i + 1}`}
              loading={i === 0 ? 'eager' : 'lazy'}
            />
          ))}
        </div>
      ) : (
        <p class="pending mono-label">RESUME PENDING — drop resume.pdf into public/</p>
      )
    }
  </main>
</Base>

<style>
  main { max-width: 52rem; }
  .head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    flex-wrap: wrap;
    padding-top: 1.8rem;
    border-bottom: 1px solid var(--line);
    padding-bottom: 1.4rem;
    margin-bottom: 1.8rem;
  }
  h1 { font-size: clamp(2.6rem, 8vw, 5.5rem); }
  .pending { color: var(--muted); }
  .preview { display: flex; flex-direction: column; gap: 1.2rem; }
  .preview img {
    width: 100%;
    height: auto;
    border: 1px solid var(--line);
    background: #fff;
  }
</style>
