---
import fs from 'node:fs';
import path from 'node:path';
import Base from '../layouts/Base.astro';

// Drop resume.pdf into public/ and the download button activates.
const pdfExists = fs.existsSync(path.join(process.cwd(), 'public', 'resume.pdf'));

const skills = [
  {
    area: 'CAD SOFTWARE',
    items: 'SolidWorks (PDM, FEA, Sheet Metal) · AutoCAD · Onshape · Autodesk Inventor · Fusion 360',
  },
  {
    area: 'LANGUAGES',
    items: 'Python (NumPy, Matplotlib) · C++ (Arduino, ESP32) · MATLAB · C',
  },
  {
    area: 'OTHER',
    items: 'CAE · 3D printing · GD&T · electrical circuits · machining · technical drawings · Excel / Word',
  },
];

const experience = [
  {
    role: 'Mechanical Team Member',
    org: 'Waterloo Aerial Robotics Group (WARG)',
    when: 'SEP 2025 – PRESENT',
    where: 'WATERLOO, ON',
    bullets: [
      'Modelled and fabricated solutions to payload tasks on the WARG Valkyrie AEAC 2026 competition drone',
      'Aided in the design, fabrication, and analysis of WARG Helios to create a working fixed-wing RC plane',
      'Collaborated with mechanical, autonomy, electrical, and software teams consisting of hundreds of members',
      'Utilized and significantly improved technical skills such as SolidWorks, FEA, and PDM',
    ],
  },
  {
    role: 'Product Development Engineer',
    org: 'JA Canada (BEARAS JA)',
    when: 'JAN 2025 – APR 2025',
    where: 'TORONTO, ON',
    bullets: [
      'Designed high-quality bear figurines by modelling with Fusion 360 CAD software to satisfy company needs',
      'Manufactured product safely by creating an air ventilation system to prevent potentially harmful emissions',
      'Optimized organic shapes for printing by testing printer settings with approximately 15 prototypes',
    ],
  },
];
---
<Base title="Resume — Benjamin Tran-Pugh">
  <main class="wrap">
    <header class="head">
      <h1 class="display">Resume<span class="dot">.</span></h1>
      {
        pdfExists ? (
          <a class="btn solid" href="/resume.pdf" download>DOWNLOAD PDF ↓</a>
        ) : (
          <span class="pending mono-label">PDF PENDING — drop resume.pdf into public/</span>
        )
      }
    </header>

    <section class="block">
      <h2 class="mono-label">EDUCATION</h2>
      <div class="row">
        <div>
          <h3>University of Waterloo</h3>
          <p class="sub">Candidate for BASc, Mechanical Engineering</p>
          <p class="sub stat">GPA 3.9 · 88% AVG</p>
        </div>
        <div class="right mono-label">
          <span>SEP 2025 – JUN 2030</span>
          <span>WATERLOO, ON</span>
        </div>
      </div>
    </section>

    <section class="block">
      <h2 class="mono-label">EXPERIENCE</h2>
      {experience.map((e) => (
        <article class="row job">
          <div>
            <h3>{e.role}</h3>
            <p class="sub">{e.org}</p>
            <ul>
              {e.bullets.map((b) => <li>{b}</li>)}
            </ul>
          </div>
          <div class="right mono-label">
            <span>{e.when}</span>
            <span>{e.where}</span>
          </div>
        </article>
      ))}
    </section>

    <section class="block">
      <h2 class="mono-label">SKILLS</h2>
      <dl class="skills">
        {skills.map((s) => (
          <div class="skill">
            <dt class="mono-label">{s.area}</dt>
            <dd>{s.items}</dd>
          </div>
        ))}
      </dl>
    </section>
  </main>
</Base>

<style>
  /* narrower, centered reading column (overrides .wrap's site-wide width) */
  main { max-width: 48rem; }
  .head {
    display: flex;
    justify-content: space-between;
    align-items: baseline;
    gap: 1rem;
    flex-wrap: wrap;
    padding-top: 1.8rem;
    border-bottom: 1px solid var(--line);
    padding-bottom: 1.4rem;
  }
  h1 { font-size: clamp(2.6rem, 8vw, 5.5rem); }
  .dot { color: var(--accent); }
  .pending { color: var(--muted); }
  .block { padding-top: 1.8rem; max-width: 50rem; }
  .block h2 { color: var(--accent); margin-bottom: 1rem; }
  .row { display: flex; justify-content: space-between; gap: 1.5rem; }
  .job { border-top: 1px solid var(--line); padding-top: 1.1rem; margin-top: 1.1rem; }
  .job:first-of-type { border-top: none; padding-top: 0; margin-top: 0; }
  h3 { font-size: 1.15rem; font-weight: 700; }
  .sub { color: var(--muted); font-size: 0.92rem; margin: 0.3rem 0 0; }
  .stat { color: var(--ink); font-weight: 500; }
  .right { display: flex; flex-direction: column; gap: 0.4rem; align-items: flex-end; color: var(--muted); white-space: nowrap; }
  ul { color: var(--muted); padding-left: 1.1rem; margin: 0.7rem 0 0; }
  li { margin: 0.3rem 0; font-size: 0.92rem; line-height: 1.55; }
  li::marker { color: var(--accent); }
  .skills { margin: 0; display: grid; gap: 0.9rem; }
  .skill { border-left: 2px solid var(--accent); padding-left: 0.9rem; }
  .skill dt { color: var(--ink); }
  .skill dd { margin: 0.25rem 0 0; color: var(--muted); font-size: 0.92rem; }
  @media (max-width: 560px) {
    .row { flex-direction: column; gap: 0.4rem; }
    .right { flex-direction: row; gap: 1rem; align-items: baseline; }
  }
</style>
